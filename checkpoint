import random

def jogar():
    # O computador pensa em um número de 1 a 100
    numero_secreto = random.randint(1, 100)
    tentativas = 0
    acertou = False

    print("="*30)
    print(" JOGO DA ADIVINHAÇÃO (1-100) ")
    print("="*30)
    print("Tente adivinhar o número que pensei!")

    # O jogo continua até o usuário acertar
    while not acertou:
        try:
            # Solicita o palpite do usuário
            palpite = int(input("\nQual é o seu palpite? "))
            tentativas += 1

            if palpite < 1 or palpite > 100:
                print("Por favor, digite um número entre 1 e 100.")
                continue

            # Verifica o palpite
            if palpite == numero_secreto:
                acertou = True
                print(f"\nPARABÉNS! Você acertou em {tentativas} tentativas.")
            elif palpite < numero_secreto:
                print("Dica: O número secreto é MAIOR.")
            else:
                print("Dica: O número secreto é MENOR.")
        
        except ValueError:
            print("Entrada inválida. Por favor, digite um número inteiro.")

# Inicia o jogo
if __name__ == "__main__":
    jogar()